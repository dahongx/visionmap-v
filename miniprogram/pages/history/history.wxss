/* 历史记录页样式 */
.container {
  padding: 30rpx;
  min-height: 100vh;
  background: #f8f9fa;
}

/* 顶部标题 */
.header {
  padding: 20rpx 0 30rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

/* 筛选标签 */
.filter-tags {
  display: flex;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.tag {
  padding: 12rpx 24rpx;
  background: white;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #666;
  border: 1rpx solid transparent;
}

.tag.active {
  background: #667eea;
  border-color: #667eea;
  color: white;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

/* 记录列表 */
.record-list {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-item:active {
  background: #f8f9fa;
}

.record-info {
  flex: 1;
}

.record-title {
  display: block;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.record-time {
  font-size: 24rpx;
  color: #999;
}

.record-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.status-tag {
  height: 34rpx;
  display: inline-flex;
  align-items: center;
  padding: 0 10rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  color: #667085;
  background: #f2f4f7;
}

.status-tag.completed {
  color: #047857;
  background: #ecfdf3;
}

.status-tag.failed {
  color: #b42318;
  background: #fef3f2;
}

.status-tag.processing {
  color: #175cd3;
  background: #eff4ff;
}

.status-tag.exported {
  color: #6941c6;
  background: #f4f3ff;
}

.record-actions {
  margin-left: 20rpx;
  min-width: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 18rpx;
}

.action-btn {
  font-size: 26rpx;
  color: #667eea;
}

.delete-btn {
  font-size: 24rpx;
  color: #c24141;
}

/* 加载提示 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-content {
  background: white;
  padding: 40rpx 60rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #666;
}
