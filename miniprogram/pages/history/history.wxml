<view class="container">
  <view class="header">
    <text class="title">历史记录</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{records.length === 0}}">
    <view class="empty-icon">📝</view>
    <text class="empty-text">暂无记录</text>
    <text class="empty-desc">去首页生成思维导图吧</text>
  </view>

  <!-- 记录列表 -->
  <view class="record-list" wx:else>
    <view
      class="record-item"
      wx:for="{{records}}"
      wx:key="_id"
      bindtap="viewRecord"
      data-id="{{item._id}}">
      <view class="record-thumb">📄</view>
      <view class="record-info">
        <text class="record-title">{{item.title || '未命名'}}</text>
        <text class="record-type">{{item.type === 'image' ? '图片' : '文档'}}转导图</text>
        <text class="record-time">{{item.createdAt}}</text>
      </view>
    </view>
  </view>
</view>

<!-- 加载提示 -->
<view class="loading-mask" wx:if="{{loading}}">
  <view class="loading-content">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>
</view>
