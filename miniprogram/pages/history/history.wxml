<view class="container">
  <!-- 顶部标题 -->
  <view class="header">
    <text class="title">我的导图</text>
  </view>

  <!-- 筛选标签 -->
  <view class="filter-tags">
    <view class="tag {{activeFilter === 'all' ? 'active' : ''}}" data-filter="all" bindtap="changeFilter">全部</view>
    <view class="tag {{activeFilter === 'edited' ? 'active' : ''}}" data-filter="edited" bindtap="changeFilter">最近编辑</view>
    <view class="tag {{activeFilter === 'exported' ? 'active' : ''}}" data-filter="exported" bindtap="changeFilter">已导出</view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{records.length === 0 && !loading}}">
    <view class="empty-icon">📝</view>
    <text class="empty-text">{{emptyText}}</text>
    <text class="empty-desc">{{emptyDesc}}</text>
  </view>

  <!-- 记录列表 -->
  <view class="record-list" wx:else>
    <view
      class="record-item"
      wx:for="{{records}}"
      wx:key="_id"
      bindtap="viewRecord"
      data-id="{{item._id}}"
      data-status="{{item.status}}">
      <view class="record-info">
        <text class="record-title">{{item.title || '未命名导图'}}</text>
        <view class="record-meta">
          <text class="status-tag {{item.status}}">{{item.status === 'completed' ? '已生成' : (item.status === 'failed' ? '失败' : '处理中')}}</text>
          <text class="status-tag exported" wx:if="{{item.isExported}}">已导出</text>
          <text class="record-time">{{activeFilter === 'edited' ? (item.updatedAtText || item.createdAt) : (activeFilter === 'exported' ? (item.exportedAtText || item.createdAt) : item.createdAt)}}</text>
        </view>
      </view>
      <view class="record-actions">
        <text class="action-btn">{{item.status === 'failed' ? '查看失败' : '继续编辑'}}</text>
        <text
          class="delete-btn"
          catchtap="deleteRecord"
          data-id="{{item._id}}"
          data-title="{{item.title || '未命名导图'}}">删除</text>
      </view>
    </view>
  </view>
</view>

<!-- 加载提示 -->
<view class="loading-mask" wx:if="{{loading}}">
  <view class="loading-content">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>
</view>
