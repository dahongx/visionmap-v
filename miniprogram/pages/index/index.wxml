<view class="container">
  <!-- 顶部积分 -->
  <view class="points-bar">
    <text class="points-text">✨ 积分 {{points}}</text>
  </view>

  <!-- 主标题区 -->
  <view class="hero">
    <text class="title">拍下手写笔记</text>
    <text class="title accent">生成可编辑导图</text>
    <text class="subtitle">自动识别笔迹，整理成清晰结构</text>
  </view>

  <!-- 核心功能标签 -->
  <view class="features">
    <view class="feature-tag">✏️ 可编辑</view>
    <view class="feature-tag">📸 可导出</view>
    <view class="feature-tag">📚 适合复习</view>
  </view>

  <!-- 上传区域 -->
  <view class="upload-area" bindtap="chooseImage">
    <view class="upload-content">
      <view class="upload-icon-box">
        <text class="upload-emoji">📝</text>
      </view>
      <view class="upload-text">
        <text class="upload-title">上传手写笔记</text>
        <text class="upload-desc">支持课堂笔记、草稿纸、白板照片</text>
      </view>
    </view>
    <text class="upload-tip">💡 文字清晰、光线充足，效果更好</text>
  </view>

  <!-- 已选择图片 -->
  <view class="selected-area" wx:if="{{tempFilePath}}">
    <image class="selected-image" src="{{tempFilePath}}" mode="aspectFill"></image>
    <view class="selected-info">
      <text class="selected-text">已选择图片</text>
      <text class="selected-action" bindtap="clearImage">重新选择</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="button-area">
    <button class="btn-main {{loading ? 'loading' : ''}}" bindtap="handleMainAction" disabled="{{loading}}">
      {{loading ? loadingText : (tempFilePath ? '开始生成导图' : '拍照生成导图')}}
    </button>
    <button class="btn-sub" bindtap="chooseFromAlbum">从相册选择</button>
  </view>

  <!-- 流程说明 -->
  <view class="flow">
    <view class="flow-step">
      <text class="flow-num">1</text>
      <text class="flow-text">拍照上传</text>
    </view>
    <view class="flow-line"></view>
    <view class="flow-step">
      <text class="flow-num">2</text>
      <text class="flow-text">自动识别</text>
    </view>
    <view class="flow-line"></view>
    <view class="flow-step">
      <text class="flow-num">3</text>
      <text class="flow-text">编辑导出</text>
    </view>
  </view>

  <!-- 最近导图 -->
  <view class="recent" wx:if="{{recentRecords.length > 0}}">
    <text class="section-title">最近导图</text>
    <view class="record-list">
      <view
        class="record-item"
        wx:for="{{recentRecords}}"
        wx:key="_id"
        bindtap="viewRecord"
        data-id="{{item._id}}">
        <text class="record-name">{{item.title || '未命名导图'}}</text>
        <text class="record-time">{{item.createdAt}}</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{recentRecords.length === 0 && !loading}}">
    <text class="empty-text">还没有生成记录</text>
    <text class="empty-desc">拍一张手写笔记试试吧 👆</text>
  </view>
</view>

<!-- 加载提示 -->
<view class="loading-mask" wx:if="{{loading}}">
  <view class="loading-box">
    <view class="loading-spinner"></view>
    <text class="loading-text">{{loadingText}}</text>
  </view>
</view>
