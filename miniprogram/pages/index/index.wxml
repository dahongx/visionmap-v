<view class="container">
  <!-- 顶部标题 -->
  <view class="header">
    <text class="title">思维导图小助手</text>
    <text class="subtitle">拍照/上传，一键生成思维导图</text>
  </view>

  <!-- 上传区域 -->
  <view class="upload-area">
    <!-- 图片上传 -->
    <view class="upload-card" bindtap="chooseImage">
      <view class="upload-icon">📷</view>
      <text class="upload-text">拍照/选择图片</text>
      <text class="upload-desc">支持JPG、PNG格式</text>
    </view>

    <!-- 文档上传 -->
    <view class="upload-card" bindtap="chooseDocument">
      <view class="upload-icon">📄</view>
      <text class="upload-text">上传文档</text>
      <text class="upload-desc">支持PDF、Word格式</text>
    </view>
  </view>

  <!-- 导图类型选择 -->
  <view class="type-section">
    <text class="section-title">选择导图类型</text>
    <view class="type-list">
      <view
        class="type-item {{selectedType === 'mindmap' ? 'active' : ''}}"
        bindtap="selectType"
        data-type="mindmap">
        <text>思维导图</text>
      </view>
      <view
        class="type-item {{selectedType === 'flowchart' ? 'active' : ''}}"
        bindtap="selectType"
        data-type="flowchart">
        <text>流程图</text>
      </view>
      <view
        class="type-item {{selectedType === 'orgchart' ? 'active' : ''}}"
        bindtap="selectType"
        data-type="orgchart">
        <text>组织架构图</text>
      </view>
    </view>
  </view>

  <!-- 积分提示 -->
  <view class="points-info">
    <text>当前积分：{{points}}</text>
    <text class="points-cost">本次消耗：{{pointsCost}}积分</text>
  </view>

  <!-- 开始生成按钮 -->
  <button class="btn-primary generate-btn" bindtap="generateMindmap" disabled="{{!canGenerate}}">
    生成思维导图
  </button>
</view>

<!-- 加载提示 -->
<view class="loading-mask" wx:if="{{loading}}">
  <view class="loading-content">
    <view class="loading-spinner"></view>
    <text class="loading-text">{{loadingText}}</text>
  </view>
</view>
