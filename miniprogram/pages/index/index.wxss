/* 首页样式 */
.container {
  padding: 30rpx;
  min-height: 100vh;
  background: #f8f9fa;
}

/* 顶部积分 */
.points-bar {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 20rpx;
}

.points-text {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
}

/* 主标题区 */
.hero {
  text-align: center;
  padding: 40rpx 0 30rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.3;
}

.title.accent {
  color: #667eea;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-top: 16rpx;
}

/* 功能标签 */
.features {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.feature-tag {
  background: white;
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

/* 上传区域 */
.upload-area {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  border: 2rpx dashed #d9d9d9;
}

.upload-area:active {
  border-color: #667eea;
  background: #f8f9ff;
}

.upload-content {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.upload-icon-box {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
}

.upload-emoji {
  font-size: 48rpx;
}

.upload-text {
  flex: 1;
}

.upload-title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.upload-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
}

.upload-tip {
  display: block;
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

/* 已选择图片 */
.selected-area {
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
}

.selected-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.selected-info {
  flex: 1;
}

.selected-text {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.selected-action {
  font-size: 26rpx;
  color: #667eea;
}

/* 操作按钮 */
.button-area {
  margin-bottom: 40rpx;
}

.btn-main {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  border: none;
}

.btn-main:active {
  opacity: 0.9;
}

.btn-main[disabled] {
  background: #ccc;
}

.btn-main.loading {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  opacity: 0.7;
}

.btn-sub {
  width: 100%;
  height: 80rpx;
  background: white;
  color: #667eea;
  font-size: 28rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #667eea;
}

.btn-sub:active {
  background: #f8f9ff;
}

/* 流程说明 */
.flow {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 50rpx;
  padding: 30rpx 0;
}

.flow-step {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.flow-num {
  width: 48rpx;
  height: 48rpx;
  background: #667eea;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.flow-text {
  font-size: 24rpx;
  color: #666;
}

.flow-line {
  width: 60rpx;
  height: 2rpx;
  background: #d9d9d9;
  margin: 0 20rpx;
  margin-bottom: 20rpx;
}

/* 最近导图 */
.recent {
  margin-bottom: 30rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.record-list {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-item:active {
  background: #f8f9fa;
}

.record-name {
  font-size: 28rpx;
  color: #333;
}

.record-time {
  font-size: 24rpx;
  color: #999;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 60rpx 0;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.empty-desc {
  display: block;
  font-size: 26rpx;
  color: #ccc;
}

/* 加载提示 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-box {
  background: white;
  padding: 50rpx 60rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}
