.container {
  min-height: 100vh;
  padding: 18rpx 18rpx 24rpx;
  background: #eef2f7;
  box-sizing: border-box;
}

.toolbar {
  height: 82rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.tool-btn {
  width: 74rpx;
  height: 74rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  border: 1rpx solid #dde4ef;
  border-radius: 8rpx;
  color: #2f3a4a;
  font-size: 34rpx;
  box-shadow: 0 4rpx 14rpx rgba(33, 43, 54, 0.06);
}

.tool-btn:active {
  background: #edf2ff;
}

.tool-btn.save {
  color: #ffffff;
  background: #344054;
  border-color: #344054;
}

.tool-btn.save.dirty {
  background: #5b7cfa;
  border-color: #5b7cfa;
}

.canvas-container {
  position: relative;
  height: calc(100vh - 326rpx);
  min-height: 760rpx;
  overflow: hidden;
  background: #ffffff;
  border: 1rpx solid #e3e9f2;
  border-radius: 8rpx;
  box-shadow: 0 6rpx 22rpx rgba(25, 34, 50, 0.06);
  touch-action: none;
}

.mindmap-canvas {
  width: 100%;
  height: 100%;
}

.selection-chip {
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  bottom: 18rpx;
  height: 54rpx;
  display: flex;
  align-items: center;
  padding: 0 18rpx;
  background: rgba(17, 24, 39, 0.78);
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 24rpx;
  box-sizing: border-box;
}

.selection-chip text {
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.action-bar,
.export-bar {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.action-btn,
.export-btn {
  height: 76rpx;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  border: 1rpx solid #dde4ef;
  border-radius: 8rpx;
  color: #344054;
  font-size: 28rpx;
  box-shadow: 0 4rpx 14rpx rgba(33, 43, 54, 0.05);
}

.action-btn:active,
.export-btn:active {
  background: #edf2ff;
}

.action-btn.danger {
  color: #c24141;
}

.export-btn.primary {
  flex: 2.2;
  background: #5b7cfa;
  border-color: #5b7cfa;
  color: #ffffff;
  font-weight: 600;
}

.export-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  z-index: -1;
  pointer-events: none;
}

.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.46);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-content {
  background: #ffffff;
  padding: 40rpx 56rpx;
  border-radius: 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid #e5e7eb;
  border-top-color: #5b7cfa;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 18rpx;
  font-size: 28rpx;
  color: #475467;
}
