<view class="container">
  <!-- 用户信息 -->
  <view class="user-section">
    <view class="avatar">👤</view>
    <view class="user-info">
      <text class="nickname">{{userInfo.nickName || '未登录'}}</text>
      <text class="points">积分：{{points}}</text>
    </view>
    <button class="login-btn" wx:if="{{!userInfo.nickName}}" bindtap="login">登录</button>
  </view>

  <!-- 积分详情 -->
  <view class="points-section">
    <view class="points-item">
      <text class="points-label">今日签到</text>
      <text class="points-value">+5</text>
    </view>
    <view class="points-item">
      <text class="points-label">邀请好友</text>
      <text class="points-value">+20</text>
    </view>
    <view class="points-item">
      <text class="points-label">购买积分卡</text>
      <text class="points-value">自定义</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="inviteFriend">
      <text class="menu-text">邀请好友</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="signIn">
      <text class="menu-text">每日签到</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="about">
      <text class="menu-text">关于我们</text>
      <text class="menu-arrow">></text>
    </view>
  </view>
</view>
