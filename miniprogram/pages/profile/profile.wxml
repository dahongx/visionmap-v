<view class="container">
  <view class="account-panel">
    <button class="avatar-button" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image wx:if="{{profileForm.avatarUrl}}" class="avatar-image" src="{{profileForm.avatarUrl}}" mode="aspectFill"></image>
      <text wx:else class="avatar-text">{{avatarText}}</text>
    </button>

    <view class="account-main">
      <view class="name-row">
        <input
          class="nickname-input"
          type="nickname"
          value="{{profileForm.nickName}}"
          maxlength="24"
          placeholder="填写昵称"
          confirm-type="done"
          bindinput="onNicknameInput" />
        <text class="status-tag">{{accountReady ? '已登录' : '初始化中'}}</text>
      </view>
      <text class="user-id">用户编号：{{user.userId || '初始化中'}}</text>
    </view>
  </view>

  <view class="profile-actions">
    <button class="primary-btn" loading="{{savingProfile}}" bindtap="saveProfile">保存资料</button>
    <button class="secondary-btn" loading="{{loadingAccount}}" bindtap="login">重新登录</button>
  </view>

  <view class="balance-panel">
    <view>
      <text class="panel-label">当前积分</text>
      <text class="balance-value">{{points}}</text>
    </view>
    <view class="balance-rule">
      <text>图片生成 10</text>
      <text>文档生成 15</text>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="signIn">
      <view>
        <text class="menu-title">每日签到</text>
        <text class="menu-subtitle">今日可领取 5 积分</text>
      </view>
      <text class="menu-action">领取</text>
    </view>

    <view class="menu-item" bindtap="showHistory">
      <view>
        <text class="menu-title">生成记录</text>
        <text class="menu-subtitle">查看当前账号下的导图</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item" bindtap="inviteFriend">
      <view>
        <text class="menu-title">邀请好友</text>
        <text class="menu-subtitle">奖励规则待正式定价后启用</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="logs-panel" wx:if="{{pointLogs.length}}">
    <view class="section-title">积分流水</view>
    <view class="log-item" wx:for="{{pointLogs}}" wx:key="_id">
      <view>
        <text class="log-reason">{{item.reason}}</text>
        <text class="log-time">{{item.createdAtText}}</text>
      </view>
      <text class="log-change {{item.changeClass}}">{{item.changeText}}</text>
    </view>
  </view>

  <view class="menu-list support-list">
    <view class="menu-item" bindtap="showHelp">
      <text class="menu-title">帮助说明</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="showFAQ">
      <text class="menu-title">常见问题</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="feedback">
      <text class="menu-title">意见反馈</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="about">
      <text class="menu-title">关于我们</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="footer">
    <text>思维导图小助手 v1.0</text>
  </view>
</view>
