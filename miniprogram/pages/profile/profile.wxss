/* 个人中心样式 */
.container {
  padding: 30rpx;
  min-height: 100vh;
  background: #f8f9fa;
}

/* 用户信息 */
.user-section {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  margin-right: 30rpx;
  font-size: 60rpx;
}

.user-info {
  flex: 1;
}

.nickname {
  display: block;
  font-size: 36rpx;
  color: white;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.points {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
}

.login-btn {
  background: white;
  color: #667eea;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
  border-radius: 30rpx;
  border: none;
}

/* 积分说明 */
.points-section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.points-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.points-title {
  font-size: 30rpx;
  color: #333;
}

.points-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #667eea;
}

.points-rule {
  background: #f8f9fa;
  padding: 16rpx;
  border-radius: 8rpx;
}

.rule-text {
  font-size: 26rpx;
  color: #666;
}

/* 功能菜单 */
.menu-section {
  background: white;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f8f9fa;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-desc {
  font-size: 26rpx;
  color: #667eea;
  margin-right: 16rpx;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* 底部说明 */
.footer {
  text-align: center;
  padding: 40rpx 0;
}

.footer-text {
  font-size: 24rpx;
  color: #ccc;
}
