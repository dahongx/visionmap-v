.container {
  min-height: 100vh;
  padding: 28rpx 28rpx 40rpx;
  box-sizing: border-box;
  background: #f4f6fb;
}

.account-panel {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #ffffff;
  border: 1rpx solid #e4e9f2;
  border-radius: 8rpx;
}

.avatar-button {
  width: 116rpx;
  height: 116rpx;
  flex: none;
  padding: 0;
  margin: 0 24rpx 0 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e9f2ff;
  border-radius: 58rpx;
  border: 1rpx solid #d5e5ff;
  overflow: hidden;
  line-height: 1;
}

.avatar-button::after {
  border: none;
}

.avatar-image {
  width: 116rpx;
  height: 116rpx;
}

.avatar-text {
  font-size: 42rpx;
  font-weight: 700;
  color: #2f6fed;
}

.account-main {
  min-width: 0;
  flex: 1;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.nickname-input {
  min-width: 0;
  flex: 1;
  height: 58rpx;
  color: #202938;
  font-size: 34rpx;
  font-weight: 700;
}

.status-tag {
  flex: none;
  height: 42rpx;
  padding: 0 16rpx;
  display: flex;
  align-items: center;
  border-radius: 8rpx;
  background: #e8f7f1;
  color: #16835f;
  font-size: 22rpx;
}

.user-id {
  display: block;
  margin-top: 10rpx;
  color: #667085;
  font-size: 24rpx;
}

.profile-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin: 18rpx 0;
}

.primary-btn,
.secondary-btn {
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 76rpx;
}

.primary-btn {
  color: #ffffff;
  background: #2f6fed;
}

.secondary-btn {
  color: #2f3a4a;
  background: #ffffff;
  border: 1rpx solid #d7deea;
}

.primary-btn::after,
.secondary-btn::after {
  border: none;
}

.balance-panel {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 20rpx;
  padding: 30rpx;
  margin-bottom: 18rpx;
  background: #202938;
  border-radius: 8rpx;
}

.panel-label {
  display: block;
  color: #a7b0c0;
  font-size: 24rpx;
}

.balance-value {
  display: block;
  margin-top: 8rpx;
  color: #ffffff;
  font-size: 58rpx;
  line-height: 1;
  font-weight: 800;
}

.balance-rule {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  color: #cbd5e1;
  font-size: 24rpx;
}

.menu-list,
.logs-panel {
  margin-bottom: 18rpx;
  background: #ffffff;
  border: 1rpx solid #e4e9f2;
  border-radius: 8rpx;
  overflow: hidden;
}

.menu-item {
  min-height: 96rpx;
  padding: 22rpx 26rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  box-sizing: border-box;
  border-bottom: 1rpx solid #edf1f6;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f6f8fc;
}

.menu-title {
  display: block;
  color: #202938;
  font-size: 29rpx;
  font-weight: 600;
}

.menu-subtitle {
  display: block;
  margin-top: 6rpx;
  color: #8a94a6;
  font-size: 23rpx;
}

.menu-action {
  flex: none;
  color: #2f6fed;
  font-size: 27rpx;
  font-weight: 600;
}

.menu-arrow {
  flex: none;
  color: #98a2b3;
  font-size: 38rpx;
  line-height: 1;
}

.section-title {
  padding: 22rpx 26rpx 8rpx;
  color: #667085;
  font-size: 24rpx;
}

.log-item {
  min-height: 82rpx;
  padding: 18rpx 26rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  border-bottom: 1rpx solid #edf1f6;
  box-sizing: border-box;
}

.log-item:last-child {
  border-bottom: none;
}

.log-reason {
  display: block;
  color: #263244;
  font-size: 27rpx;
}

.log-time {
  display: block;
  margin-top: 4rpx;
  color: #98a2b3;
  font-size: 22rpx;
}

.log-change {
  flex: none;
  font-size: 28rpx;
  font-weight: 700;
}

.log-change.plus {
  color: #16835f;
}

.log-change.minus {
  color: #c24141;
}

.support-list {
  margin-top: 18rpx;
}

.footer {
  padding: 28rpx 0 10rpx;
  text-align: center;
  color: #a1a9b7;
  font-size: 23rpx;
}
